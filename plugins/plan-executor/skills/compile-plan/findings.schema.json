{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://plan-executor/schemas/findings.schema.json",
  "title": "plan-executor code-review findings input",
  "description": "Input to compile-plan APPEND mode. Each finding becomes one or more fix-tasks in a new fix-wave appended to an existing tasks.json manifest.",
  "type": "object",
  "required": ["findings"],
  "additionalProperties": false,
  "properties": {
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "severity", "category", "description"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "severity": { "enum": ["critical", "major", "minor", "nit"] },
          "category": { "type": "string", "minLength": 1 },
          "description": { "type": "string", "minLength": 1 },
          "files": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          },
          "suggested_fix": { "type": "string" }
        }
      }
    }
  }
}
