{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://parloa.dev/plan-executor/skills/run-reviewer-team-non-interactive/input.schema.json",
  "title": "run-reviewer-team-non-interactive input",
  "description": "Input envelope for the run-reviewer-team-non-interactive helper skill.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "mode",
    "plan_context",
    "execution_outputs",
    "changed_files",
    "language",
    "recipe_list",
    "prior_review_context",
    "execution_root",
    "attempt"
  ],
  "properties": {
    "mode": {
      "type": "string",
      "enum": ["dispatch", "triage"]
    },
    "plan_context": {
      "type": "string",
      "minLength": 1
    },
    "execution_outputs": {
      "type": "string",
      "minLength": 1
    },
    "changed_files": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "language": {
      "type": "string",
      "enum": ["typescript", "python", "go", "rust", "unknown"]
    },
    "recipe_list": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "prior_review_context": {
      "type": "object"
    },
    "execution_root": {
      "type": "string",
      "minLength": 1
    },
    "attempt": {
      "type": "integer",
      "minimum": 1
    },
    "reviewer_outputs": {
      "type": "object",
      "additionalProperties": false,
      "required": ["claude", "security"],
      "properties": {
        "claude":   { "type": "string" },
        "codex":    { "type": "string" },
        "gemini":   { "type": "string" },
        "security": { "type": "string" }
      }
    }
  },
  "allOf": [
    {
      "if": { "properties": { "mode": { "const": "triage" } } },
      "then": { "required": ["reviewer_outputs"] }
    }
  ]
}
