{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://parloa.dev/plan-executor/skills/review-execution-output-non-interactive/input.schema.json",
  "title": "review-execution-output-non-interactive input",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "plan_path",
    "execution_root",
    "changed_files",
    "language",
    "recipe_list",
    "skip_code_review",
    "state_file_path",
    "execution_state",
    "review_state",
    "review_state_path",
    "prior_review_notes"
  ],
  "properties": {
    "plan_path":          { "type": "string", "minLength": 1 },
    "execution_root":     { "type": "string", "minLength": 1 },
    "changed_files": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "language": {
      "type": "string",
      "enum": ["typescript", "python", "go", "rust", "unknown"]
    },
    "recipe_list": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "skip_code_review":   { "type": "boolean" },
    "state_file_path":    { "type": "string", "minLength": 1 },
    "execution_state":    { "type": "object" },
    "review_state":       { "type": ["object", "null"] },
    "review_state_path":  { "type": "string", "minLength": 1 },
    "prior_review_notes": { "type": "object" },
    "reviewer_team_result": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "next_step", "notes", "state_updates"],
      "properties": {
        "status":        { "type": "string", "enum": ["success", "fix_required", "blocked", "abort"] },
        "next_step":     { "type": "string", "enum": ["proceed", "dispatch_fix_wave", "escalate", "terminate"] },
        "notes":         { "type": "string" },
        "state_updates": { "type": "object" }
      }
    },
    "compile_fix_waves_result": {
      "type": "object",
      "additionalProperties": false,
      "required": ["exit_code", "appended_fix_wave_ids", "stderr"],
      "properties": {
        "exit_code": { "type": "integer" },
        "appended_fix_wave_ids": {
          "type": "array",
          "items": { "type": "integer", "minimum": 100 }
        },
        "stderr": { "type": "string" }
      }
    },
    "prior_handoff_outputs_path": {
      "description": "Absolute path to the JSON sidecar carrying the dispatched sub-agent outputs the orchestrator just collected. Empty (or absent) on the first invocation (dispatch mode); non-empty on the re-invocation that follows a `waiting_for_handoffs` envelope (triage mode). Sidecar shape: an array of `{ index, exit_code, output, stderr }` entries.",
      "type": "string"
    }
  }
}
